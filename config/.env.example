# OPENLAB Radar - Variables de entorno
# Copia este fichero a .env y rellena los valores

# YouTube Data API key (Google Cloud Console)
YOUTUBE_API_KEY=tu-api-key-aquí

# Telegram Bot
# 1. Habla con @BotFather en Telegram, crea un bot
# 2. Copia el token aquí
TELEGRAM_BOT_TOKEN=tu-bot-token-aquí

# Telegram - Briefing diario (solo Rafael, bidireccional via Claude Code Channel)
# Chat ID personal de Rafael (para el Claude Code Channel)
TELEGRAM_CHAT_ID=tu-chat-id-aquí

# Telegram - Digest semanal (canal broadcast para el equipo OPENLAB)
# 1. Crear canal en Telegram (ej: "OPENLAB Radar")
# 2. Activar comentarios en hilo (Linked Group)
# 3. Añadir el bot como administrador del canal (permiso: Post Messages)
# 4. El ID del canal es negativo y empieza por -100 (ej: -1001234567890)
#    Para obtenerlo: publica algo en el canal, luego:
#    curl https://api.telegram.org/bot<TOKEN>/getUpdates | python3 -m json.tool
#    Busca "chat": {"id": -100...} en el resultado
TELEGRAM_CHANNEL_ID=tu-channel-id-aquí

# Email - Digest semanal (gws CLI, mismos destinatarios que el canal Telegram)
# Lista separada por comas. El email sale desde tu cuenta Gmail autenticada con gws.
# Setup: brew install googleworkspace-cli && gws auth setup
DIGEST_EMAIL_RECIPIENTS=rafa@openlabstudio.com,equipo@openlabstudio.com

# Telegraph - Artículos Instant View para Telegram
# Se genera automáticamente en la primera ejecución de publish_telegraph.py.
# Copia aquí el token que imprime por stderr y guárdalo.
TELEGRAPH_ACCESS_TOKEN=
